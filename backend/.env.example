PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/saas-manager
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_RESET_SECRET=your_reset_secret_here
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# SMTP Config for development (Ethereal)
# Leave empty to generate test account automatically, or provide explicit Ethereal credentials
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
